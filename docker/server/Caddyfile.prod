# Prod — Caddy écoute sur :80, Traefik (Coolify) gère SSL/TLS en amont
:80 {
    encode gzip zstd

    # WebSocket : Socket.IO standalone
    handle /socket.io/* {
        reverse_proxy socket:3001
    }

    # Next.js
    handle {
        reverse_proxy app:3000
    }

    log {
        output stdout
        format json
    }
}